# Live bot mode: paper | live-dryrun | live
# NOTE: 'live' currently falls back to live-dryrun until broker SDK integration is added.
HEDGEBOT_EXECUTION_MODE=paper

# Symbol and data path
HEDGEBOT_SYMBOL=SPY
HEDGEBOT_DATA_ROOT=data

# Strategy source (generated by hedge_bot sweep)
HEDGEBOT_USE_BEST_STRATEGY=1
HEDGEBOT_STRATEGY_FILE=results/best_strategy.yaml

# Runtime controls
HEDGEBOT_INITIAL_CASH=100000
HEDGEBOT_MAX_STEPS=240

# Placeholder API credentials (replace with real values later)
BROKER_API_KEY=demo_broker_key_1f7a9c
BROKER_API_SECRET=demo_broker_secret_9d3c2b
DATA_API_KEY=demo_market_data_key_6a2d11
